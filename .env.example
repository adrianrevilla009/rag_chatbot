# ═══════════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO
#
# Copia este fichero a ".env" y rellena tus valores.
# NUNCA commitees el .env real a git. El .env.example sí va a git.
#
# ¿Por qué variables de entorno y no hardcodear en el código?
# 12-Factor App (estándar de aplicaciones productivas): la configuración
# que cambia entre entornos (dev/staging/prod) SIEMPRE va en env vars.
# Así el mismo código corre en todos los entornos sin modificarlo.
# ═══════════════════════════════════════════════════════════════════════════

# ─── LLM ──────────────────────────────────────────────────────────────────
# Consigue tu key gratis en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Base de datos ────────────────────────────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# ─── Entorno ──────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | production
